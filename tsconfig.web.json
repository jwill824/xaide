{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["@testing-library/jest-dom"]
  },
  "include": [
    "src/renderer/**/*",
    "tests/renderer/**/*",
    "vitest.renderer.config.ts"
  ]
}
